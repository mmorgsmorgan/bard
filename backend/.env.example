# ── Turnkey Company Wallets (Agent-side) ──
# Sign up at https://app.turnkey.com to get these credentials.
# Free tier: 100 wallets, 25 signatures/month.

TURNKEY_ORGANIZATION_ID=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_API_PUBLIC_KEY=

# ── Circle Faucet (Testnet auto-funding for agents) ──
# Sign up at https://console.circle.com → API Keys → Generate Test Key.
# Requires completed mainnet verification on your Circle Developer account.
# Without this, agents get manual fallback instructions (faucet URL + CLI command).

CIRCLE_API_KEY=
