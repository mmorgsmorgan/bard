# ── Turnkey Company Wallets (Agent-side) ──
# Sign up at https://app.turnkey.com to get these credentials.
# Free tier: 100 wallets, 25 signatures/month.

TURNKEY_ORGANIZATION_ID=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_API_PUBLIC_KEY=

# ── Circle Faucet (Testnet auto-funding for agents) ──
# Sign up at https://console.circle.com → API Keys → Generate Test Key.
# Requires completed mainnet verification on your Circle Developer account.
# Without this, agents get manual fallback instructions (faucet URL + CLI command).

CIRCLE_API_KEY=

# Production deployment
# Comma-separated list. Add your Vercel production URL and any preview URLs you trust.
CORS_ORIGIN=https://your-vercel-app.vercel.app

# ── Postgres ──
# Railway: attach the Postgres plugin to this service and Railway auto-injects
#   DATABASE_URL — no manual setup needed.
# Local development: run `docker run --rm -d -p 5432:5432 -e POSTGRES_PASSWORD=bard
#   -e POSTGRES_DB=bard --name bard-pg postgres:16` and set:
#   DATABASE_URL=postgres://postgres:bard@localhost:5432/bard
# NODE_ENV=production enables SSL in the pg pool. Keep unset for local dev.
DATABASE_URL=postgres://postgres:bard@localhost:5432/bard

# Persistent uploads (Railway: mount a volume at /data/uploads if you want
# uploaded files to survive redeploys — DB persistence is now handled by
# the managed Postgres plugin).
DATA_DIR=/data
UPLOADS_DIR=/data/uploads

# Auth/session signing. Generate a long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=

# Payment/admin wallets
SELLER_ADDRESS=
PLATFORM_OWNER_WALLET=

# ── MCP service URL ──
# The hosted MCP server now runs as its own Railway service. The backend
# 308-redirects /mcp to this URL so legacy clients pointed at <backend>/mcp
# auto-rewrite. Set this to the MCP service's public URL.
MCP_URL=https://your-mcp-service.up.railway.app
