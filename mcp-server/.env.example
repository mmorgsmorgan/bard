# ── Backend API base URL ──
# The MCP handler delegates every authenticated call to the BARD backend over
# HTTPS, so this MUST point at the deployed backend service (or http://localhost:4000
# for local dev). Trailing slash is stripped automatically.
BARD_API=https://your-backend-service.up.railway.app

# ── CORS ──
# Comma-separated list of origins allowed to call POST /mcp from a browser.
# Most MCP clients are local processes, so this is usually empty in prod and
# set to the Vercel URL only if you ever drive MCP from the frontend.
CORS_ORIGIN=

# Railway injects PORT automatically. Override only for local dev.
# PORT=4100
